{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "System-wide user profile with RBAC support.",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "store"] },
        "storeId": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "DarkStore": {
      "title": "DarkStore",
      "type": "object",
      "description": "Store metadata and tactical metrics.",
      "properties": {
        "storeId": { "type": "string" },
        "storeName": { "type": "string" },
        "ownerUid": { "type": "string" },
        "metrics": {
          "type": "object",
          "properties": {
            "totalOrders": { "type": "integer" },
            "activeRiders": { "type": "integer" },
            "revenue": { "type": "number" },
            "stockHealth": { "type": "integer" }
          }
        }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Private node for user profiles and store-specific subcollections."
    },
    "/darkStores/{storeId}": {
      "schema": { "$ref": "#/entities/DarkStore" },
      "description": "Global store directory for admin oversight."
    },
    "/app_admins/{userId}": {
      "schema": { "type": "object" },
      "description": "Admin registry for RBAC elevation."
    }
  }
}
