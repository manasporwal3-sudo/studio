rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEURO·FAST SOVEREIGN SECURITY RULES — v12.0 MASTER BOOTSTRAP
     * Implements master email bypass and explicit collection-level permissions.
     */

    // --- GLOBAL HELPERS ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Master Admin check - evaluates directly from the Auth Token for zero-latency bypass.
    function isMasterAdmin() {
      return isSignedIn() && request.auth.token.email == 'admin@neurofast.io';
    }

    function isAdmin() {
      return isMasterAdmin() || 
        (isSignedIn() && (
          exists(/databases/$(database)/documents/app_admins/$(request.auth.uid)) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        ));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    // GLOBAL ACCESS FOR ADMINS
    // Explicitly allows recursive access for any node identified as Admin.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // USERS & STORES MESH
    match /users {
      allow list: if isAdmin();
      
      match /{userId} {
        allow get: if isOwner(userId) || isAdmin();
        allow create: if isSignedIn(); // Allow initial creation during signup/provisioning
        allow update: if isOwner(userId) || isAdmin();
        
        // Recursive access for all store-specific data
        match /{allSubcollections=**} {
          allow read, write: if isOwner(userId) || isAdmin();
        }
      }
    }

    // RIDERS (Shared fleet management)
    match /riders/{riderId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (resource != null && resource.data.darkStoreId == request.auth.uid);
    }

    // PLATFORM ACTIVITY (Global logs)
    match /platform_activity/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }
    
    // ADMIN REGISTRY
    match /app_admins/{userId} {
      allow read: if isAdmin();
      allow write: if isAdmin(); 
    }
  }
}