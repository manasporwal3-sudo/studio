rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEURO·FAST SOVEREIGN SECURITY RULES — v11.0 MASTER BOOTSTRAP
     * Implements master email bypass for bootstrap and recursive RBAC.
     */

    // --- GLOBAL HELPERS ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Admins are defined by their master email, or document presence in app_admins or users.
    // This allows admin@neurofast.io to bootstrap the system even if documents aren't yet created.
    function isAdmin() {
      return isSignedIn() && 
        (request.auth.token.email == 'admin@neurofast.io' ||
         exists(/databases/$(database)/documents/app_admins/$(request.auth.uid)) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    // GLOBAL ACCESS FOR ADMINS (Covers collectionGroup queries and platform oversight)
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // STORE OWNER SANDBOXING
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isSignedIn(); // Allow initial creation during signup
      allow update: if isOwner(userId);
      
      // Recursive access for all store-specific data
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // RIDERS (Shared fleet management)
    match /riders/{riderId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (resource != null && resource.data.darkStoreId == request.auth.uid);
    }

    // ADMIN REGISTRY
    match /app_admins/{userId} {
      allow get: if isSignedIn();
      allow write: if isAdmin(); 
    }
    
    // PLATFORM ACTIVITY (Global logs)
    match /platform_activity/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn(); // Allow any node to log activity
    }
  }
}