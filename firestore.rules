rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEURO-FAST SECURITY RULES
     * 
     * PHILOSOPHY:
     * This ruleset implements a robust, decentralized authorization model designed for high-performance 
     * quick-commerce operations. It prioritizes "Authorization Independence" by leveraging heavy 
     * data denormalization. By storing a 'members' map (UID to Role) directly on every operational 
     * document, we eliminate the need for costly cross-document lookups (get() calls) during 
     * security evaluations.
     * 
     * DATA STRUCTURE:
     * - User Profiles: Isolated under /userProfiles/{userId} for private management.
     * - Global Catalogs: /products and /vendors are globally readable but restricted to 
     *   Global Managers (identified via the /global_managers/ collection).
     * - Dark Store Ecosystem: All operational data (Inventory, Sales, Forecasts, Orders, Alerts) 
     *   is nested under /darkStores/{darkStoreId}. Every document in this tree contains a 
     *   denormalized 'members' map from the parent store for instant authorization.
     * 
     * KEY SECURITY DECISIONS:
     * 1. Shared Access: Access to store-specific data is governed by the 'members' map on each document.
     * 2. Relational Integrity: Rules strictly enforce that documents created within a store path 
     *    must contain the correct 'darkStoreId' in their body.
     * 3. Immutability: Critical relationship links (like store association) are immutable once created.
     * 4. Prototyping Flexibility: Schema validation (types/required fields) is bypassed to allow 
     *    rapid iteration, focusing purely on secure access control.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Checks if the user exists in the global_managers collection (DBAC: Existence over Content)
    function isGlobalManager() {
      return isSignedIn() && exists(/databases/$(database)/documents/global_managers/$(request.auth.uid));
    }

    // Checks if the user is a member based on the 'members' map in the document data
    function isMember(data) {
      return isSignedIn() && data.members[request.auth.uid] != null;
    }

    // Validation helper for existence and membership on update/delete
    function isExistingMember() {
      return resource != null && isMember(resource.data);
    }

    // Relational integrity check: Ensure data link matches the URL path
    function matchesPathStore(data, darkStoreId) {
      return data.darkStoreId == darkStoreId;
    }

    // Enforce that a field cannot be changed after creation
    function isImmutable(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for user-specific profile data.
     * @path /userProfiles/{userId}
     * @allow Authenticated user (create/get/list/update) their own profile.
     * @deny Any user attempting to access a different user's profile.
     * @principle Ownership-based access control.
     */
    match /userProfiles/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && isImmutable('id');
      allow delete: if isOwner(userId);
    }

    /**
     * @description System-level role collection for managers.
     * @path /global_managers/{userId}
     * @allow User to read their own manager status.
     * @deny Direct writes by users (typically handled by admin/system process).
     * @principle DBAC (Database-Based Access Control) for global roles.
     */
    match /global_managers/{userId} {
      allow get: if isOwner(userId);
      allow list: if isSignedIn(); // Allow discovery of managers
      allow create, update, delete: if false; // System-managed
    }

    /**
     * @description Core Dark Store master data.
     * @path /darkStores/{darkStoreId}
     * @allow Members of the store (read); Store Admins (write).
     * @deny Users not in the 'members' map.
     * @principle Shared access via denormalized membership map.
     */
    match /darkStores/{darkStoreId} {
      allow get, list: if isMember(resource.data);
      allow create: if isGlobalManager(); 
      allow update: if isMember(resource.data) && (resource.data.members[request.auth.uid] == 'Admin' || resource.data.members[request.auth.uid] == 'Store Manager');
      allow delete: if isGlobalManager();
    }

    /**
     * @description Operational data subcollections (Inventory, Sales, Forecasts, Orders, Alerts).
     * @path /darkStores/{darkStoreId}/{collection}/{id}
     * @allow Any authorized member of the specific Dark Store.
     * @deny Access if the UID is not present in the denormalized 'members' map of the document.
     * @principle Authorization Independence via denormalized members map.
     */
    match /darkStores/{darkStoreId}/{collection}/{id} {
      allow get, list: if isMember(resource.data);
      
      allow create: if isMember(request.resource.data) 
                    && matchesPathStore(request.resource.data, darkStoreId);

      allow update: if isExistingMember() 
                    && isMember(request.resource.data)
                    && isImmutable('darkStoreId');

      allow delete: if isExistingMember();

      // Nested items for Procurement Orders
      match /items/{itemId} {
        allow get, list: if isMember(resource.data);
        allow create: if isMember(request.resource.data) && matchesPathStore(request.resource.data, darkStoreId);
        allow update: if isExistingMember() && isMember(request.resource.data) && isImmutable('darkStoreId');
        allow delete: if isExistingMember();
      }
    }

    /**
     * @description Global Product Catalog.
     * @path /products/{productId}
     * @allow All signed-in users (read). Global Managers (write).
     * @deny Write access for standard store managers or employees.
     * @principle Public read with restricted role-based writes.
     */
    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isGlobalManager();
    }

    /**
     * @description Global Vendor Catalog and associated data.
     * @path /vendors/{vendorId}
     * @allow Signed-in users (read catalog). Members of the vendor map or Global Managers (write).
     * @principle Shared access map for vendor-specific integration data.
     */
    match /vendors/{vendorId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isGlobalManager();

      // Vendor Integration Configurations
      match /integrationConfigurations/{configId} {
        allow get, list: if isMember(resource.data) || isGlobalManager();
        allow create: if isMember(request.resource.data) || isGlobalManager();
        allow update: if (isExistingMember() || isGlobalManager()) && isImmutable('vendorId');
        allow delete: if isExistingMember() || isGlobalManager();
      }
    }
  }
}