rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEURO·FAST SOVEREIGN — v17.0 SUPREME SECURITY PROTOCOL
     * Implements absolute recursive God-Mode for master administrative identities.
     */

    // --- GLOBAL HELPERS ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Master Admin check - evaluates directly from the Auth Token for absolute bypass.
    function isMasterAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@neurofast.io' || 
        request.auth.token.email == 'system.apex@neurofast.io'
      );
    }

    // --- SUPREME GOD MODE BYPASS ---
    // Grants absolute recursive read/write access across the entire database.
    match /{allDocuments=**} {
      allow read, write: if isMasterAdmin();
    }

    // Explicitly allow collection listing for the master admin to populate the dashboard matrix.
    match /users {
      allow list: if isMasterAdmin();
    }

    // Explicitly allow collection group queries for the 'inventory' ID.
    match /{path=**}/inventory/{itemId} {
      allow read: if isMasterAdmin();
    }

    // --- CORE COLLECTION RULES ---

    match /users/{userId} {
      allow get, update: if isSignedIn() && (request.auth.uid == userId || isMasterAdmin());
      allow create: if isSignedIn();
      allow list: if isMasterAdmin();
      
      match /{allSubcollections=**} {
        allow read, write: if (isSignedIn() && request.auth.uid == userId) || isMasterAdmin();
      }
    }

    match /riders/{riderId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if resource != null && (resource.data.darkStoreId == request.auth.uid || isMasterAdmin());
    }

    match /platform_activity/{logId} {
      allow create: if isSignedIn();
      allow read: if isMasterAdmin();
    }
    
    match /app_admins/{userId} {
      allow read, write: if isMasterAdmin();
    }
  }
}