rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEURO·FAST SOVEREIGN — v14.0 APEX SECURITY PROTOCOL
     * Implements absolute recursive God-Mode for master administrative identities.
     * v14.0 adds explicit list authorization for the global user registry.
     */

    // --- GLOBAL HELPERS ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Master Admin check - evaluates directly from the Auth Token for absolute bypass.
    function isMasterAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@neurofast.io' || 
        request.auth.token.email == 'system.apex@neurofast.io'
      );
    }

    // --- SUPREME GOD MODE BYPASS ---
    // Grants absolute recursive read/write access to the master identity across the entire database.
    match /{allDocuments=**} {
      allow read, write: if isMasterAdmin();
    }

    // --- CORE COLLECTION RULES ---

    match /users {
      // Explicitly allow listing the users collection for administrative oversight.
      allow list: if isMasterAdmin();
    }

    match /users/{userId} {
      // Allow operators to manage their own node profiles.
      allow get, update: if isSignedIn() && request.auth.uid == userId;
      // Allow initial enrollment.
      allow create: if isSignedIn();
      
      // Recursive access for all store-specific subcollections (Inventory, Orders, etc.)
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // --- FLEET & LOGISTICS ---

    match /riders/{riderId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if resource != null && (resource.data.darkStoreId == request.auth.uid || isMasterAdmin());
    }

    // --- PLATFORM TELEMETRY ---

    match /platform_activity/{logId} {
      allow create: if isSignedIn();
      allow read: if isMasterAdmin();
    }
    
    match /app_admins/{userId} {
      allow read, write: if isMasterAdmin();
    }
  }
}