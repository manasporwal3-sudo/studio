rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEURO·FAST SOVEREIGN SECURITY RULES — v10.0 GOD MODE
     * Implements recursive RBAC and multi-tenant sandboxing.
     */

    // --- GLOBAL HELPERS ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Admins are defined by their document presence in the app_admins collection
    // or a role field in their user profile.
    function isAdmin() {
      return isSignedIn() && 
        (exists(/databases/$(database)/documents/app_admins/$(request.auth.uid)) ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    // GLOBAL ACCESS FOR ADMINS
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // STORE OWNER SANDBOXING
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isSignedIn(); // Allow initial creation during signup
      allow update: if isOwner(userId);
      
      // Recursive access for all store-specific data
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // RIDERS (Shared fleet management)
    match /riders/{riderId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (resource != null && resource.data.darkStoreId == request.auth.uid);
    }

    // ADMIN REGISTRY
    match /app_admins/{userId} {
      allow get: if isSignedIn();
      allow write: if false; // Only manageable via Firebase Console or special script
    }
  }
}
